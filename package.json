{
  "name": "lesson-studio",
  "version": "0.1.0",
  "description": "Authoring app and DSL definition for the Bridge Classroom lesson library.",
  "license": "Unlicense",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "print:pdf": "node scripts/print-pdf.mjs",
    "pdf:attach": "node scripts/pdf-attach.mjs",
    "pdf:extract": "node scripts/pdf-extract.mjs",
    "lint:lessons": "tsx scripts/lint-lessons.ts"
  },
  "dependencies": {
    "@milkdown/core": "^7.5.0",
    "@milkdown/ctx": "^7.5.0",
    "@milkdown/plugin-listener": "^7.21.2",
    "@milkdown/preset-commonmark": "^7.5.0",
    "@milkdown/prose": "^7.5.0",
    "@milkdown/transformer": "^7.5.0",
    "@milkdown/vue": "^7.5.0",
    "@prosemirror-adapter/vue": "^0.5.3",
    "vue": "^3.5.13",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "happy-dom": "^20.10.6",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.61.1",
    "tsx": "^4.23.0",
    "typescript": "~5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.2.0"
  }
}
